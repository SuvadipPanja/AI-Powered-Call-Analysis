# Backend environment configuration (EXAMPLE)
# Copy this file to `.env` and fill in real values. NEVER commit a real `.env`.
# All secrets below are placeholders and must be replaced for production.

# === Project Base Directory ===
PROJECT_ROOT=/path/to/AI-Powered Call Analysis project
Project log="/path/to/AI-Powered Call Analysis project"

# === Server Configuration ===
PORT=5000
WS_PORT=8080

# === Database Configuration ===
DB_USER="your_db_user"
DB_PASSWORD="change-me"
DB_SERVER=YOUR_SQL_SERVER\INSTANCE
DB_USE_WINDOWS_AUTH=true
DB_PORT=1433
DB_DATABASE="call_analysis_db"
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# === Directory Paths ===
BACKEND_LOG_DIR="${Project log}/logs/Backend Log"
DETAILS_LOG_DIR="${Project log}/logs/Details_Log"
ACTION_LOG_DIR="logs"
LICENSE_LOG_DIR="${Project log}/logs/License_Log"

PYTHON_SCRIPT_LOG_FILE="python_script.log"
UPLOAD_HANDLER_LOG_FILE="upload_handler.log"
ACTION_LOG_FILE="action.log"
LICENSE_LOG_FILE="license.log"

AUDIO_UPLOAD_DIR="/path/to/data/Sample_Audio"
CHAT_DUMP_DIR="/path/to/data/Chat_Dump"
PROFILE_PICS_DIR="assets/profile_pictures"

# === AI Model Path ===
MODEL_PATH="/models/DeepSeek-R1-Distill-Qwen-1.5B"

# === Security Settings ===
# Comma-separated CORS allowlist (no wildcard). Requests with no Origin header
# (server-to-server, curl) are always allowed.
#
# Development (local React dev server):
#   CORS_ORIGIN="http://localhost:3000"
#
# Production (HTTPS frontend only — add every allowed origin):
#   CORS_ORIGIN="https://your-domain.com,https://www.your-domain.com"
#
# Dev + staging combined:
#   CORS_ORIGIN="http://localhost:3000,https://staging.your-domain.com"
CORS_ORIGIN="http://localhost:3000"

# Enforce session-token auth on all non-public API routes. Keep true in prod.
API_AUTH_ENFORCE=true

# Shared service token for trusted server-to-server clients (e.g. AutoUpload).
# Generate a long random value, e.g. `node -e "require('crypto').randomBytes(32).toString('hex')"`.
# Leave blank to disable.
SERVICE_TOKEN=

# Shared secret the backend sends to the AI orchestrator (must match
# ai-mvp/.env ORCHESTRATOR_SECRET). Generate: node -e "require('crypto').randomBytes(32).toString('hex')"
# Required in production.
ORCHESTRATOR_SECRET=

# Secret for the internal transcription callback (must match ai-mvp CALLBACK_SECRET).
# Generate with the same command as ORCHESTRATOR_SECRET (use a different value).
# Required in production.
CALLBACK_SECRET=

# Secret key used to decode the license (32 chars). REQUIRED.
LICENSE_SECRET_KEY=replace-with-32-char-secret

# License file path (relative to backend directory).
LICENSE_FILE_PATH="./license/license.lic"

# === Host MAC for license validation ===
HOST_MAC=00:00:00:00:00:00

# === AI MVP orchestrator (Phase 1) ===
AI_MAIN_URL=http://localhost:8000
REDIS_URL=redis://localhost:6379
