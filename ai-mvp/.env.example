# AI MVP orchestrator environment (EXAMPLE)
# Copy to `.env` and fill in real values. NEVER commit a real `.env`.

PROJECT_ROOT=C:/Project/AI-Powered Call Analysis project
AUDIO_UPLOAD_DIR=C:/Project/AI-Powered Call Analysis project/data/Sample_Audio
LOG_DIR=C:/Project/AI-Powered Call Analysis project/logs/ai-mvp
PORT=8000

# Database (orchestrator writes directly when DB_ENABLED=true)
DB_SERVER=YOUR_SQL_SERVER\INSTANCE
DB_DATABASE=call_analysis_db
DB_USE_WINDOWS_AUTH=true
DB_USER=your_db_user
DB_PASSWORD=change-me

# Phase 1 — shared secrets with backend (must match backend/.env exactly)
# Generate: node -e "require('crypto').randomBytes(32).toString('hex')"
ORCHESTRATOR_SECRET=
CALLBACK_SECRET=

# Backend callback when DB_ENABLED=false (remote GPU / no SQL from orchestrator)
BACKEND_CALLBACK_URL=http://localhost:5000/api/internal/transcription-callback

# Transcription backend: faster-whisper | nemo | whisper-large-v3 | auto
TRANSCRIBE_BACKEND=faster-whisper
FASTER_WHISPER_MODEL_SIZE=large-v3

# Ollama scoring (Phase 2b)
SCORING_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b
