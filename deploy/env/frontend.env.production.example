# =============================================================================
# FRONTEND — production build-time .env template
# =============================================================================
# Copy to the build machine as:  frontend/.env.production
# Values are baked into the JS bundle at `npm run build` — rebuild after changes.
# NEVER put secrets here (REACT_APP_* is public in the browser).
# =============================================================================

# Same origin as nginx (HTTPS). API routes are proxied at /api/ by nginx.
REACT_APP_API_BASE_URL=https://calls.YOUR_COMPANY.com

# WebSocket via nginx location /ws (see deploy/nginx.conf.example)
REACT_APP_WS_URL=wss://calls.YOUR_COMPANY.com/ws

REACT_APP_ENV=production
REACT_APP_LOGIN_BACKGROUND_URL=/images/background.jpg
REACT_APP_LOG_DIR=/opt/call-analysis/logs/frontend
