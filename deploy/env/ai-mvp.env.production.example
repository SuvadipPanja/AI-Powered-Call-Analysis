# =============================================================================
# AI-MVP ORCHESTRATOR — production .env template
# =============================================================================
# Copy to the server as:  /opt/call-analysis/ai-mvp/.env
# Orchestrator must stay on localhost or a private network (port 8000).
# =============================================================================

PROJECT_ROOT=/opt/call-analysis
AUDIO_UPLOAD_DIR=/opt/call-analysis/data/Sample_Audio
LOG_DIR=/opt/call-analysis/logs/ai-mvp
PORT=8000

# Database (same as backend if DB_ENABLED=true)
DB_SERVER=YOUR_SQL_HOST\INSTANCE
DB_DATABASE=call_analysis_db
DB_USE_WINDOWS_AUTH=false
DB_USER=call_analysis_app
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# Must match backend/.env exactly
ORCHESTRATOR_SECRET=SAME_AS_BACKEND_ORCHESTRATOR_SECRET
CALLBACK_SECRET=SAME_AS_BACKEND_CALLBACK_SECRET

# Backend internal callback URL (localhost — not the public domain)
BACKEND_CALLBACK_URL=http://127.0.0.1:5000/api/internal/transcription-callback

TRANSCRIBE_BACKEND=faster-whisper
FASTER_WHISPER_MODEL_SIZE=large-v3

SCORING_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3:8b
