# =============================================================================
# BACKEND — production .env template
# =============================================================================
# Copy to the server as:  /opt/call-analysis/backend/.env
# Replace every YOUR_* placeholder before starting the backend.
# Generate secrets:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =============================================================================

NODE_ENV=production

# === Public domain (used in logs / docs only — CORS is the real allowlist) ===
# Primary site: https://calls.YOUR_COMPANY.com
PUBLIC_APP_URL=https://calls.YOUR_COMPANY.com

# === Server ===
PORT=5000
# WebSocket shares PORT (Express HTTP server). WS_PORT is legacy/unused in most setups.

# === Database (SQL Server — use SQL auth on Linux; Windows auth only on Windows) ===
DB_SERVER=YOUR_SQL_HOST\INSTANCE
DB_DATABASE=call_analysis_db
DB_PORT=1433
DB_USE_WINDOWS_AUTH=false
DB_USER=call_analysis_app
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=false

# === Paths (Linux production layout) ===
PROJECT_ROOT=/opt/call-analysis
Project log=/opt/call-analysis

BACKEND_LOG_DIR=/opt/call-analysis/logs/Backend Log
DETAILS_LOG_DIR=/opt/call-analysis/logs/Details_Log
ACTION_LOG_DIR=/opt/call-analysis/backend/logs
LICENSE_LOG_DIR=/opt/call-analysis/logs/License_Log

PYTHON_SCRIPT_LOG_FILE=python_script.log
UPLOAD_HANDLER_LOG_FILE=upload_handler.log
ACTION_LOG_FILE=action.log
LICENSE_LOG_FILE=license.log

AUDIO_UPLOAD_DIR=/opt/call-analysis/data/Sample_Audio
CHAT_DUMP_DIR=/opt/call-analysis/data/Chat_Dump
PROFILE_PICS_DIR=/opt/call-analysis/backend/assets/profile_pictures

# === AI orchestrator (internal — localhost only, never expose port 8000 publicly) ===
AI_MAIN_URL=http://127.0.0.1:8000
REDIS_URL=redis://127.0.0.1:6379
MODEL_PATH=/opt/models/DeepSeek-R1-Distill-Qwen-1.5B

# === Security ===
# Must match the HTTPS origin users open in the browser (comma-separated, no wildcard).
CORS_ORIGIN=https://calls.YOUR_COMPANY.com

API_AUTH_ENFORCE=true

# Server-to-server upload (must match AutoUpload/.env SERVICE_TOKEN)
SERVICE_TOKEN=GENERATE_64_CHAR_HEX

# Must match ai-mvp/.env exactly (two different values — generate twice)
ORCHESTRATOR_SECRET=GENERATE_64_CHAR_HEX
CALLBACK_SECRET=GENERATE_64_CHAR_HEX_DIFFERENT

# 32-character license decode key (from your license vendor / internal process)
LICENSE_SECRET_KEY=REPLACE_WITH_32_CHAR_KEY____
LICENSE_FILE_PATH=./license/license.lic

# Server MAC address bound to your production license file
# Linux: ip link show | grep ether
HOST_MAC=aa:bb:cc:dd:ee:ff
