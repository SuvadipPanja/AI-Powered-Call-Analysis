# =============================================================================
# AUTO UPLOAD — production .env template
# =============================================================================
# Copy to the batch server as:  /opt/call-analysis/AutoUpload/.env
# Can run on the same host as the backend or a dedicated ingest server.
# =============================================================================

PROJECT_BASE_DIR=/opt/call-analysis/AutoUpload

METADATA_DIR=/opt/call-analysis/AutoUpload/metadata
AUDIO_DIR=/opt/call-analysis/AutoUpload/audio
LOG_DIR=/opt/call-analysis/AutoUpload/logs

AUTO_UPLOADER_LOG_FILE=auto_uploader.log

# Internal backend URL (localhost if co-located; use private IP if separate server)
API_BASE_URL=http://127.0.0.1:5000

# Must match backend/.env SERVICE_TOKEN
SERVICE_TOKEN=SAME_AS_BACKEND_SERVICE_TOKEN

PROCESSING_DATE_DELTA=1
