# =============================================================================
# FRONTEND — production build (NO DOMAIN — use server IP)
# =============================================================================
# Copy to: frontend/.env.production  then run: npm run build
# Replace YOUR_SERVER_IP with the same IP used in backend CORS_ORIGIN
# =============================================================================

# --- Option A: HTTP (internal pilot / VPN only) ---
REACT_APP_API_BASE_URL=http://YOUR_SERVER_IP
REACT_APP_WS_URL=ws://YOUR_SERVER_IP/ws

# --- Option B: Self-signed HTTPS (uncomment, comment Option A, rebuild) ---
# REACT_APP_API_BASE_URL=https://YOUR_SERVER_IP
# REACT_APP_WS_URL=wss://YOUR_SERVER_IP/ws

REACT_APP_ENV=production
REACT_APP_LOGIN_BACKGROUND_URL=/images/background.jpg
