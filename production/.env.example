# =============================================================================
#  AI-Powered Call Analysis — PRODUCTION environment
#  Copy this file to ".env"  (cp .env.example .env)  and fill in real values.
#  This single file is used BOTH for docker-compose interpolation (${VAR})
#  and as the backend container's env_file. NEVER commit the real .env.
# =============================================================================

# ---- Public address of THIS server (IP or domain, no http://) --------------
# The browser uses this to reach the backend. If it changes, rebuild the
# frontend image (scripts/00-build-and-save-images.sh).
# Example (no domain):  10.64.194.130
PUBLIC_HOST=10.64.194.130

# ---- Database (SQL Server) -------------------------------------------------
# Strong SA password (>= 8 chars, upper+lower+digit+symbol). The database is
# restored from Database/backup.bak on first start as "call_analysis_db".
SA_PASSWORD=ChangeMe_Str0ng!Pass

# ---- License (MAC-locked) --------------------------------------------------
# Keep HOST_MAC equal to the MAC your license was issued for, and place the
# matching license file at  production/license/license.lic .
HOST_MAC=34:E1:2D:1A:79:80
# 32-character secret used to decode the license (backend only).
LICENSE_SECRET_KEY=replace-with-exactly-32-char-secret

# ---- Service-to-service secrets (generate random 64-hex each) --------------
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ORCHESTRATOR_SECRET=
CALLBACK_SECRET=
SERVICE_TOKEN=

# ---- CORS ------------------------------------------------------------------
# Origin(s) the browser loads the app from. Must include the frontend URL.
# Frontend is published on port 8081 by this compose file.
CORS_ORIGIN=http://10.64.194.130:8081

# ---- Backend internal wiring (usually leave as-is) -------------------------
API_AUTH_ENFORCE=true
AI_MAIN_URL=http://ai:8000
REDIS_URL=redis://redis:6379

# ---- Backend paths (required — docker-compose also sets these for the container) ----
PROJECT_ROOT=/app
BACKEND_LOG_DIR=/app/logs
DETAILS_LOG_DIR=/app/logs/details
PYTHON_SCRIPT_LOG_FILE=python_script.log
UPLOAD_HANDLER_LOG_FILE=upload_handler.log
CHAT_DUMP_DIR=/app/data/Chat_Dump
PROFILE_PICS_DIR=/app/assets/profile_pictures
BRANDING_DIR=/app/uploads/branding
ACTION_LOG_DIR=/app/logs
ACTION_LOG_FILE=action.log

CALL_PROCESSING_LOG_FILE=call_processing.log

# ---- LLM (vLLM — GPU index 1 on dual-GPU host; dev laptop uses Ollama) ----
LLM_SERVED_NAME=Meta-Llama-3.1-8B-Instruct
LLM_MODEL_PATH=/models/Meta-Llama-3.1-8B-Instruct-AWQ
LLM_MAX_MODEL_LEN=8192
LLM_QUANTIZATION=awq
# ai + llm share one physical GPU — lower (0.15–0.35) if ai restarts during transcribe
LLM_GPU_MEMORY_UTIL=0.35
OPENAI_API_KEY=local-prod
OPENAI_MAX_TOKENS=2048

# Language detection device: cpu avoids cuDNN crash when sharing GPU with llm + faster-whisper
# WHISPER_LANG_DEVICE=cpu

# Optional local CT2 weights (extract from models-bundle.tgz)
# FASTER_WHISPER_MODEL_PATH=/models/faster-whisper-large-v3

# ---- Docker isolation (dual-GPU server: GPU 0 = other team, GPU 1 = this stack) ----
COMPOSE_PROJECT_NAME=call-analysis-prod
DOCKER_NETWORK_NAME=call-analysis-prod-net
# Host GPU index (0-based). Use 1 when GPU 0 is reserved for another application.
GPU_DEVICE_ID=1
# Change only if these host ports clash with another stack:
# BACKEND_HTTP_PORT=5000
# BACKEND_WS_PORT=8080
# FRONTEND_HTTP_PORT=8081
