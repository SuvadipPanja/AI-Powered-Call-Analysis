# Frontend environment configuration (EXAMPLE)
# Copy this file to `.env` and adjust values. NEVER commit a real `.env`.
#
# IMPORTANT: Anything prefixed with REACT_APP_ is embedded into the public
# client bundle at build time. Do NOT put secrets here. License validation is
# performed entirely server-side; there is intentionally no license secret.

REACT_APP_API_BASE_URL=http://localhost:5000
REACT_APP_LOG_DIR=/app/logs
REACT_APP_ENV=production
REACT_APP_LOGIN_BACKGROUND_URL=/images/background.jpg
REACT_APP_WS_URL=ws://localhost:5000
